# ============================================================
#  .env.example — Variables d'environnement
#  cp .env.example .env && nano .env avant de démarrer
# ============================================================

# ── REDIS ──────────────────────────────────────────────────
REDIS_PASSWORD=change_me_very_secure_redis_password
REDIS_HOST_PORT=127.0.0.1:6379
REDIS_MEM_LIMIT=768M

# ── REDIS EXPORTER (doit correspondre à users.acl) ─────────
REDIS_EXPORTER_USER=appuser
REDIS_EXPORTER_PASSWORD=CHANGE_ME_APP_PASSWORD

# ── RABBITMQ ───────────────────────────────────────────────
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=change_me_very_secure_rabbit_password
RABBITMQ_VHOST=/
RABBITMQ_HOST_PORT=127.0.0.1:5672
RABBITMQ_MGMT_PORT=127.0.0.1:15672
RABBITMQ_PROM_PORT=127.0.0.1:15692
RABBITMQ_MEM_WATERMARK=1536MB
RABBITMQ_MEM_LIMIT=2G

# ── PROMETHEUS ─────────────────────────────────────────────
PROMETHEUS_RETENTION=15d

# ── GRAFANA ────────────────────────────────────────────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=change_me_grafana_admin_password
