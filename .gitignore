# ============================================================
#  .gitignore — Redis + RabbitMQ Stack
# ============================================================

# ── Secrets — NEVER COMMIT ─────────────────────────────────
.env
.env.backup.*
*.key
*.pem
*.crt
*.p12

# ── Downloaded Grafana dashboards (regeneratable) ──────────
grafana/provisioning/dashboards/*.json

# ── Local Docker data (if bind-mounted) ────────────────────
data/
volumes/

# ── Local backups ───────────────────────────────────────────
*.rdb
backup-*.rdb
backup-*.tar.gz

# ── Logs ────────────────────────────────────────────────────
*.log
logs/

# ── macOS ───────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# ── Editors ─────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── Node (if JS scripts are added later) ────────────────────
node_modules/
